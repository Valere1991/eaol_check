    {
      "name": "06 - Run causal analysis - margin drop",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_id\": \"demo\",\n  \"case_id\": \"pilot-margin-drop-prod-a-april-2026\",\n  \"question\": \"Pourquoi la marge du produit Hydraulic Pump A a-t-elle chuté en avril 2026 ?\",\n  \"signals\": [\n    {\n      \"type\": \"transaction\",\n      \"name\": \"Raw material cost increase for Hydraulic Pump A\",\n      \"value\": 21.9,\n      \"unit\": \"% above baseline\",\n      \"source\": \"ERP\",\n      \"confidence\": 0.92\n    },\n    {\n      \"type\": \"supplier\",\n      \"name\": \"Supplier ACME on-time delivery degradation\",\n      \"value\": \"71% on-time delivery, high risk\",\n      \"source\": \"Procurement\",\n      \"confidence\": 0.88\n    },\n    {\n      \"type\": \"incident\",\n      \"name\": \"Line 3 bottleneck after missing components\",\n      \"value\": \"18 hours downtime, 58000 EUR impact\",\n      \"source\": \"MES\",\n      \"confidence\": 0.9\n    },\n    {\n      \"type\": \"incident\",\n      \"name\": \"Seal defect detected during QA\",\n      \"value\": \"14300 EUR rework impact\",\n      \"source\": \"QMS\",\n      \"confidence\": 0.79\n    },\n    {\n      \"type\": \"document\",\n      \"name\": \"Supplier ACME escalation email\",\n      \"value\": \"component shortage and delayed shipments for Pump A\",\n      \"source\": \"SharePoint\",\n      \"confidence\": 0.76\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/causal-analysis",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "causal-analysis"
          ]
        }
      }
    },
    {
      "name": "07 - Start root-cause workflow",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"case_id\": \"{{case_id}}\",\n  \"workflow_key\": \"eaol-root-cause-analysis\",\n  \"variables\": {\n    \"product_id\": \"PROD-A\",\n    \"supplier_id\": \"SUP-ACME\",\n    \"severity\": \"high\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/workflows/start",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "workflows",
            "start"
          ]
        }
      }
    },
